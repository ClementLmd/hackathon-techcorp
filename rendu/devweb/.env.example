# URL du serveur d'inference (endpoint OpenAI-compatible).
# Ollama expose /v1 par defaut sur le port 11434.
# A remplacer par l'URL fournie par l'equipe INFRA si besoin.
OLLAMA_BASE_URL=http://localhost:11434/v1

# Nom exact du modele charge dans le serveur d'inference.
# A confirmer avec l'equipe INFRA (ex: phi3.5, phi3-financial, ...).
OLLAMA_MODEL=phi3.5
